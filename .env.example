# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# Set these in your Vercel project dashboard for production.
# ─────────────────────────────────────────────────────────────────────────────

# OpenRouter API key — get it from https://openrouter.ai/keys
# ⚠️  NO "REACT_APP_" prefix — this is used by the Vercel serverless function only
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# Firebase is configured directly in src/lib/firebase.js using the
# firebaseConfig object. Replace FIREBASE_CONFIG_PLACEHOLDER there.
# ─────────────────────────────────────────────────────────────────────────────
